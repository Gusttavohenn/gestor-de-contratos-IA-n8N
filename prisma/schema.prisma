// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Contract {
  id            String   @id @default(uuid())
  name          String
  fileName      String
  status        String   @default("Analisando")
  aiSummary     String?
  validityDate  String?
  cnpj          String?
  contact       String?
  value         String?
  monthlyValue  String?
  company       String?
  category      String?
  renewal       String?
  manager       String?
  createdAt     DateTime @default(now())
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
}

model Manager {
  id    String @id @default(uuid())
  name  String @unique
}